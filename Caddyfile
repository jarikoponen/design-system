# Caddy serverar statiska Astro-builden på port 8080.
# Dokploys Traefik gör HTTPS-terminering utåt; därför ingen Let's Encrypt här.

{
	# Stäng av admin-API i container (säkerhet) och Caddys auto-HTTPS (Traefik tar det).
	admin off
	auto_https off
}

:8080 {
	root * /srv

	# Korrekta MIME-types. Caddys default ger application/octet-stream för .md –
	# vi måste explicit sätta text/markdown så att AI-verktyg läser dem rätt.
	@markdown path *.md
	header @markdown Content-Type "text/markdown; charset=utf-8"

	@llms path /llms.txt /llms-full.txt
	header @llms Content-Type "text/plain; charset=utf-8"
	header @llms Cache-Control "no-cache, must-revalidate"

	# Säkerhetsheaders för HTML
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		# CSP håller vi medvetet löst – Starlight + Pagefind använder inline-script.
	}

	# Gzip + brotli för alla textbaserade format
	encode zstd gzip

	# Statisk filservering med trailing-slash-normalisering som Astro förväntar sig
	file_server {
		precompressed gzip
	}

	# Generic 404 – Astro byggde en /404.html, låt Caddy använda den
	handle_errors {
		@404 expression `{err.status_code} == 404`
		rewrite @404 /404.html
		file_server
	}
}
